# Azure Event Hubs Configuration
# Replace the values below with your actual credentials

# The connection string for the Event Hubs namespace
EVENT_HUB_CONNECTION_STR="Endpoint=sb://<your-namespace>.servicebus.windows.net/;SharedAccessKeyName=<your-key-name>;SharedAccessKey=<your-key>"

# The name of the specific Event Hub
EVENT_HUB_NAME="<your-event-hub-name>"
